// Prisma Schema for Gharpayy CRM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW_LEAD
  CONTACTED
  REQUIREMENT_COLLECTED
  PROPERTY_SUGGESTED
  VISIT_SCHEDULED
  VISIT_COMPLETED
  BOOKED
  LOST
}

enum LeadSource {
  WHATSAPP
  WEBSITE_FORM
  SOCIAL_MEDIA
  PHONE_CALL
  GOOGLE_FORM
  LEAD_QUESTIONNAIRE
  REFERRAL
  OTHER
}

enum VisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum UserRole {
  ADMIN
  AGENT
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(AGENT)
  phone         String?
  avatar        String?
  activeLeads   Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignedLeads Lead[]
  activities    LeadActivity[]
  notes         Note[]
  visits        Visit[]

  @@map("users")
}

model Lead {
  id            String     @id @default(cuid())
  name          String
  phone         String
  email         String?
  source        LeadSource
  status        LeadStatus @default(NEW_LEAD)
  budget        String?
  preferredArea String?
  moveInDate    String?
  occupation    String?
  notes         String?

  assignedToId  String?
  assignedTo    User?      @relation(fields: [assignedToId], references: [id])

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastActivityAt DateTime  @default(now())

  activities    LeadActivity[]
  leadNotes     Note[]
  visits        Visit[]

  @@map("leads")
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  type        String   // status_change, note_added, visit_scheduled, call_made, etc.
  description String
  metadata    String?  // JSON string for extra data
  createdAt   DateTime @default(now())

  @@map("lead_activities")
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}

model Visit {
  id           String      @id @default(cuid())
  leadId       String
  lead         Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agentId      String
  agent        User        @relation(fields: [agentId], references: [id])
  propertyName String
  visitDate    DateTime
  visitTime    String
  status       VisitStatus @default(SCHEDULED)
  outcome      String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("visits")
}
